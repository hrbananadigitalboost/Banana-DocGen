DATABASE_URL="postgresql://user:password@localhost:5432/bdb_docgen?schema=public"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
# Wajib diisi "true" saat deploy ke platform selain Vercel (mis. Railway) -
# Auth.js v5 cuma auto-trust host di platform yang dikenalinya sendiri.
# Tanpa ini, endpoint /api/auth/* akan error "UntrustedHost" di produksi.
AUTH_TRUST_HOST="true"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@bananadigitalboost.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
